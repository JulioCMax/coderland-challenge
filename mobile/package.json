{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "@reduxjs/toolkit": "^2.12.0",
    "expo": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --watchAll=false --coverage",
    "tsc": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
    "collectCoverageFrom": ["src/**/*.{ts,tsx}", "!src/**/*.d.ts"],
    "testTimeout": 30000,
    "moduleNameMapper": {
      "^immer$": "<rootDir>/node_modules/immer/dist/cjs/index.js",
      "^react-redux$": "<rootDir>/node_modules/react-redux/dist/cjs/index.js"
    }
  },
  "private": true
}
